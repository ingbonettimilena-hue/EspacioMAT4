# Resend API Key
# Obtén tu API key en: https://resend.com/api-keys
# Necesitas verificar tu dominio en Resend para enviar emails
RESEND_API_KEY=

# Google Analytics
# Obtén tu ID de medición en: https://analytics.google.com/
# Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Google Maps
# Obtén tu API key en: https://console.cloud.google.com/google/maps-apis
# Habilita: Maps JavaScript API, Places API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google OAuth (NextAuth)
# Obtén las credenciales en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
# Genera un secret con: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000